# FastAPI CORS origins for direct browser-to-API calls.
# Leave localhost entries in place for local development.
VOLSTREAM_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://your-frontend-domain.vercel.app

# Optional regex for preview deployments with changing subdomains.
# Example:
# VOLSTREAM_CORS_ORIGIN_REGEX=https://.*\.vercel\.app
